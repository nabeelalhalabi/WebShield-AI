{
  "name": "webshield-ai-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.popup.config.ts",
    "build": "vite build --config vite.popup.config.ts && vite build --config vite.background.config.ts && vite build --config vite.content.config.ts",
    "preview": "vite preview --config vite.popup.config.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^25.7.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.1",
    "typescript": "^5.5.4",
    "vite": "^6.0.0",
    "vitest": "^2.0.5"
  }
}