WEBSHIELD_DEBUG=true
WEBSHIELD_TEXT_TOXICITY_MODEL=unitary/toxic-bert
WEBSHIELD_HATE_SPEECH_MODEL=facebook/roberta-hate-speech-dynabench-r4-target
WEBSHIELD_NSFW_MODEL=Falconsai/nsfw_image_detection
WEBSHIELD_VIOLENCE_MODEL=jaranohaal/vit-base-violence-detection
WEBSHIELD_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
WEBSHIELD_SQLITE_PATH=.runtime/webshield.db
WEBSHIELD_SETTINGS_PATH=.runtime/user_preferences.json
WEBSHIELD_DOMAIN_RULES_PATH=.runtime/domain_rules.json
WEBSHIELD_ENABLE_REMOTE_LLM=false
WEBSHIELD_LLM_API_BASE=
WEBSHIELD_LLM_API_KEY=
